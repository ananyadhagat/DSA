class Solution {
    public void rotate(int[] nums, int k) {
       int l= nums.length;
        k=k%l;
        int start=l-k;
       
        if(l<=1) return;
        if(k==0) return;
        int[] temp = new int[l];
        for(int i=0; i<k; i++){
       
        temp[i]=nums[start+i];
        }    
        
         
        for(int i=0; i<start;i++){
       
        
        temp[i+k]=nums[i];
        }
        for(int i=0; i<l; i++){
            nums[i]=temp[i];       
         }
    }
} 
